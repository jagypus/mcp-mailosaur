  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "mailosaur": "^11.0.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.8.0"
  }
